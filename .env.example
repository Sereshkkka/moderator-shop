HOST=127.0.0.1
PORT=4174
PUBLIC_APP_URL=http://localhost:4174

# Supabase Database Settings > Connection string > URI
# Direct connection works for small projects when your network supports it.
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.tiplvmplutoybajoksat.supabase.co:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_CONNECTION_TIMEOUT_MS=10000

# Local PostgreSQL container. Use a long random password in production.
POSTGRES_DB=modshop
POSTGRES_USER=modshop
POSTGRES_PASSWORD=CHANGE_TO_A_LONG_RANDOM_PASSWORD

# After migration, replace DATABASE_URL with this local connection:
# DATABASE_URL=postgresql://modshop:CHANGE_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/modshop
# DATABASE_SSL=false

# Discord OAuth
DISCORD_OAUTH_CLIENT_ID=1492710758658871336

# Public Supabase project values used by the browser only if Supabase Auth is enabled.
SUPABASE_URL=https://tiplvmplutoybajoksat.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional one-time migration from another PostgreSQL database to Supabase.
SOURCE_DATABASE_URL=postgres://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/coin_system
SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.tiplvmplutoybajoksat.supabase.co:5432/postgres
SUPABASE_DATABASE_SSL=true
# CONFIRM_MIGRATION=copy-to-supabase

# One-time PostgreSQL-to-PostgreSQL copy.
# MIGRATION_SOURCE_DATABASE_URL=postgresql://...
# MIGRATION_TARGET_DATABASE_URL=postgresql://modshop:...@postgres:5432/modshop
# MIGRATION_SOURCE_DATABASE_SSL=true
# MIGRATION_TARGET_DATABASE_SSL=false
# CONFIRM_POSTGRES_COPY=copy-postgres-data
