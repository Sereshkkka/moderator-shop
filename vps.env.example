HOST=0.0.0.0
PORT=4174
PUBLIC_APP_URL=https://YOUR_DOMAIN_OR_SERVER_IP

# Supabase Postgres connection.
# Replace YOUR_DATABASE_PASSWORD with the real database password.
DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.tiplvmplutoybajoksat.supabase.co:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_CONNECTION_TIMEOUT_MS=10000

# Local PostgreSQL container. Generate a new long password.
POSTGRES_DB=modshop
POSTGRES_USER=modshop
POSTGRES_PASSWORD=CHANGE_TO_A_LONG_RANDOM_PASSWORD

# Use this DATABASE_URL only after the migration command succeeds:
# DATABASE_URL=postgresql://modshop:CHANGE_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/modshop
# DATABASE_SSL=false

# Discord OAuth
DISCORD_OAUTH_CLIENT_ID=1492710758658871336

# Public Supabase project values used by the browser.
SUPABASE_URL=https://tiplvmplutoybajoksat.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
